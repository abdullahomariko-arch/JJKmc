# ─────────────────────────────────────────────────────────────────────────────
# VISUAL HOOK: jjk_visual energy_discharge_hit <player> <world> <x> <y> <z>
#
# Called when an Energy Discharge passive strike hits a target.
# Replace the placeholder below with your custom particle effects.
# ─────────────────────────────────────────────────────────────────────────────
on command "jjk_visual":
    # Placeholder — add your visual logic here
