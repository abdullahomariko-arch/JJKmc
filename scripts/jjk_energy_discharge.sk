    # set {_x} to argument 4 parsed as number
    # set {_y} to argument 5 parsed as number
    # set {_z} to argument 6 parsed as number
    # spawn 10 dust particles using dustOption(blue, 1.5) at location({_x}, {_y}, {_z}, world({_world}))
